{
  "name": "yclaw",
  "version": "0.1.0",
  "description": "YCLAW installer CLI — guided setup, validation, and deployment",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "yclaw": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@yclaw/core": "*",
    "commander": "^12.0.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "ora": "^8.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "5.7",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
