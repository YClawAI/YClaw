# YCLAW Supply Chain Security — 7-day soaking period
# Reject any package version published less than 7 days ago.
# npm v10.9+ required. Critical security patches bypass this via Renovate config.
# npm expects a numeric day count here, not a duration string like "7d".
min-release-age=7

# Disable arbitrary pre/post install scripts from dependencies
# This prevents malicious postinstall execution (DPRK's primary attack vector)
ignore-scripts=true

# Enforce strict lockfile usage
package-lock=true

# Audit settings
audit=true
audit-level=moderate

# Pin exact versions by default
save-exact=true
