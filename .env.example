# ============================================================================
# YCLAW Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED to boot the stack via `docker compose up`:
#   - At least one LLM provider API key (ANTHROPIC_API_KEY recommended)
#
# Everything else is optional — leave blank unless you're enabling that
# integration. Secrets belong in your shell, an untracked .env, or AWS
# Secrets Manager for deployed environments.
#
# IMPORTANT: Do NOT put inline comments after `=` on any line. Docker Compose's
# `env_file` parser treats everything after `=` as the value, including any
# trailing `# comment`. Always put comments on their own line ABOVE the key.
# ============================================================================

# ---------------------------------------------------------------------------
# Docker Compose knobs
# ---------------------------------------------------------------------------
# Override host ports if 3000/3001/5432/6379/27017 are already in use.
#
# NOTE: Default database URLs below use Docker Compose service hostnames
# (mongo, redis, postgres). If running outside Docker, change these to
# localhost or your hosted database endpoints.

# Host port for the YCLAW core API
API_PORT=3000
# Host port for Mission Control
MC_PORT=3001
# Local-only password for the bundled postgres
POSTGRES_PASSWORD=yclaw_dev

# ---------------------------------------------------------------------------
# Core runtime
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=3000
# Default branch for GitHub operations (main for YCLAW)
DEFAULT_BRANCH=main
YCLAW_WEBHOOK_PORT=3100
# Core runtime logger level
YCLAW_LOG_LEVEL=info
# ACPX logger level
LOG_LEVEL=info
YCLAW_LOG_DIR=

# Database connection strings — defaults match the bundled docker-compose
# service hostnames. If you point YCLAW at external databases, set these to
# your hosted endpoints.
REDIS_URL=redis://redis:6379
MONGODB_URI=mongodb://mongo:27017/yclaw
MONGODB_DB=yclaw_agents
# Legacy fallback used by the audit logger
YCLAW_DB_NAME=
# sslmode=disable is required for the bundled postgres container which does
# not speak SSL. Change to sslmode=require for managed services like RDS.
MEMORY_DATABASE_URL=postgresql://yclaw:yclaw_dev@postgres:5432/yclaw_memory?sslmode=disable

# Absolute path inside the container — local file backend for IObjectStore
YCLAW_OBJECT_STORE_PATH=/app/data/objects
# One-time bootstrap token for root operator setup
YCLAW_SETUP_TOKEN=

# Protects core /api routes when set
YCLAW_API_KEY=
YCLAW_API_URL=http://localhost:3000
NEXT_PUBLIC_YCLAW_API_URL=http://localhost:3000
EMAIL_ALLOWED_DOMAINS=
COMMIT_SHA=
GIT_COMMIT=
ECS_TASK_ARN=

# ---------------------------------------------------------------------------
# LLM providers and routing
# ---------------------------------------------------------------------------

# LLM provider keys — at least one is required to boot.
# Get from console.anthropic.com (recommended default)
ANTHROPIC_API_KEY=
# (optional) OAuth bearer token — alternative to ANTHROPIC_API_KEY
ANTHROPIC_OAUTH_TOKEN=
# Get from platform.openai.com
OPENAI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=

# Default LLM routing (overridable per-agent in departments/*.yaml)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-7
# Defaults to LLM_PROVIDER when blank
ONBOARDING_LLM_PROVIDER=
# Defaults to LLM_MODEL when blank
ONBOARDING_MODEL=

# Azure OpenAI — set these instead of OPENAI_API_KEY to route via Azure (optional)
AZURE_OPENAI_API_KEY=
# e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# e.g. 2024-12-01-preview
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_RESOURCE_NAME=
AZURE_OPENAI_BASE_URL=
# JSON map of model → deployment, e.g. {"gpt-4o":"my-gpt4o"}
AZURE_OPENAI_DEPLOYMENT_NAME_MAP=

# Optional OpenAI-compatible proxy base URL
LITELLM_PROXY_URL=
LITELLM_API_KEY=
# Used by the LiteLLM proxy task definition
LITELLM_DATABASE_URL=

# ---------------------------------------------------------------------------
# Codegen, ACPX, and Builder tuning
# ---------------------------------------------------------------------------

# pi | cli | acp (deprecated) | auto
EXECUTOR_TYPE=pi
# Legacy: ACPX_SERVICE_URL and ACPX_API_KEY removed — Pi replaces ACP
PI_CODING_AGENT_ENABLED=true
PI_DEFAULT_MODEL=claude-opus-4-7
PI_DEFAULT_PROVIDER=anthropic
SESSION_TTL_MS=7200000
MAX_CONCURRENT_SESSIONS=50

CODEGEN_WORKSPACES_DIR=
CODEGEN_SKILLS_DIR=
CODEGEN_STUCK_MINUTES=60
DEFAULT_STUCK_MINUTES=30

BUILDER_MAX_WORKERS=
BUILDER_P3_PROMOTION_AGE_MS=
BUILDER_DLQ_MAX_SIZE=
BUILDER_DLQ_RETRY_INTERVAL_MS=
BUILDER_DLQ_MAX_RETRIES=
BUILDER_MAX_QUEUE_DEPTH=
BUILDER_BACKPRESSURE_THRESHOLD=
BUILDER_CORRELATION_MAX_AGE_MS=

REACTION_LOOP_ENABLED=true
BUDGET_ENFORCEMENT_ENABLED=false
# Approval/governance mode: off, notify, gate-destructive, or strict
GOVERNANCE_MODE=off
# Budget mode: enforcing, tracking (default), off
BUDGET_MODE=tracking
# Cost threshold in cents — actions above this need approval (default: $100)
COST_APPROVAL_THRESHOLD_CENTS=10000

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------

# Prompt caching on LLM calls (default: true; set false to disable)
FF_PROMPT_CACHING=true
# Compress conversation context before LLM call (default: false)
FF_CONTEXT_COMPRESSION=false
# Scan agent memory writes for sensitive content (default: false)
FF_MEMORY_SCANNER=false
# Write agent knowledge to Obsidian vault (default: false)
FF_OBSIDIAN_GATEWAY=false

# ---------------------------------------------------------------------------
# Review gate
# ---------------------------------------------------------------------------

# LLM used by the Reviewer agent
REVIEW_MODEL=claude-sonnet-4-5-20250929
# FAIL_OPEN (default) or FAIL_CLOSED
REVIEW_FAILURE_STRATEGY=FAIL_OPEN

# Compliance checker profile: oss-framework (default) or financial-regulated
# oss-framework checks for credential leaks, harmful content, impersonation.
# financial-regulated adds SEC/financial compliance on top of OSS checks.
COMPLIANCE_PROFILE=oss-framework

# ---------------------------------------------------------------------------
# Root operator (seed.ts — sets up the initial operator account)
# ---------------------------------------------------------------------------

# Display name for the root operator
ROOT_OPERATOR_NAME=
# Email for the root operator account
ROOT_OPERATOR_EMAIL=
# API key provisioned for the root operator on first seed
ROOT_API_KEY=

# ---------------------------------------------------------------------------
# Mission Control — NextAuth
# ---------------------------------------------------------------------------

# NextAuth session encryption — REQUIRED for Mission Control login.
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=
# Must match MC's public URL
NEXTAUTH_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Mission Control
# ---------------------------------------------------------------------------

NEXT_PUBLIC_ORG_NAME=
ECS_CLUSTER_NAME=
ECS_SERVICE_NAME=
MC_API_KEY=
MISSION_CONTROL_APPROVER_ID=mission-control
VAULT_PATH=

OPENCLAW_URL=
OPENCLAW_GATEWAY_TOKEN=
NEXT_PUBLIC_OPENCLAW_URL=
GATEWAY_WS_URL=
GATEWAY_DEVICE_PUBLIC_KEY=
GATEWAY_DEVICE_PRIVATE_KEY=
GATEWAY_DEVICE_FINGERPRINT=
GATEWAY_SKIP_DEVICE_AUTH=

AGENTHUB_URL=
AGENTHUB_DISPATCHER_KEY=
# JSON map, e.g. {"worker-1":"..."}
AGENTHUB_WORKER_KEYS=
AGENTHUB_INTERNAL_URL=
AGENTHUB_MC_API_KEY=
# Used by scripts/register-agents.sh
AGENTHUB_ADMIN_KEY=

GROWTH_ENGINE_API_KEY=
GROWTH_ENGINE_CONFIG_DIR=
GROWTH_ENGINE_AGENT_ID=growth-engine
GROWTH_ENGINE_APPROVAL_COUNT=

# ---------------------------------------------------------------------------
# GitHub Authentication
# ---------------------------------------------------------------------------
# Option A: GitHub App (recommended — auto-refreshing tokens, fine-grained permissions)
# Create via the onboarding flow at /v1/onboarding/github/install or manually
# at https://github.com/settings/apps/new
GITHUB_APP_ID=
# PEM private key — raw multi-line, base64-encoded, or an absolute file path
GITHUB_APP_PRIVATE_KEY=
# Set after installing the app on your org/account
GITHUB_APP_INSTALLATION_ID=

# Case-sensitive default repo for agent GitHub actions
GITHUB_OWNER=
GITHUB_REPO=

# Option B: Personal Access Token (simpler setup, manual rotation)
GITHUB_TOKEN=

# GitHub webhook secret (required for either auth method)
GITHUB_WEBHOOK_SECRET=

# Instance URL (used for manifest generation and webhook URL)
YCLAW_EXTERNAL_URL=

# Bot identity for agent assignee matching (comma-separated GitHub usernames)
AGENT_ASSIGNEES=
APPROVED_DEPLOYERS=

VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ---------------------------------------------------------------------------
# Slack / Discord
# ---------------------------------------------------------------------------

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_URL=
SLACK_ALLOWED_CHANNEL_IDS=
# Slack channel for escalation alerts (optional)
YCLAW_ALERTS_CHANNEL=#yclaw-alerts

# Per-department Slack channel IDs. Leave blank to fall back to the
# legacy #yclaw-<dept> channel names. Setting any of these overrides the
# default for that department across every Slack notifier.
SLACK_CHANNEL_GENERAL=
SLACK_CHANNEL_EXECUTIVE=
SLACK_CHANNEL_DEVELOPMENT=
SLACK_CHANNEL_MARKETING=
SLACK_CHANNEL_OPERATIONS=
SLACK_CHANNEL_FINANCE=
SLACK_CHANNEL_SUPPORT=
SLACK_CHANNEL_ALERTS=
SLACK_CHANNEL_AUDIT=

# Discord bot token — set to auto-enable the Discord channel adapter.
# Create a bot at https://discord.com/developers/applications, copy the
# token, invite the bot to your server with the Send Messages permission,
# then fill in the channel IDs below.
DISCORD_BOT_TOKEN=

# Per-department Discord channel IDs. Right-click a channel in Discord
# (with Developer Mode enabled) and pick "Copy Channel ID". Leave any
# blank to route that department to DISCORD_CHANNEL_GENERAL instead.
DISCORD_CHANNEL_GENERAL=
DISCORD_CHANNEL_EXECUTIVE=
DISCORD_CHANNEL_DEVELOPMENT=
DISCORD_CHANNEL_MARKETING=
DISCORD_CHANNEL_OPERATIONS=
DISCORD_CHANNEL_FINANCE=
DISCORD_CHANNEL_SUPPORT=
DISCORD_CHANNEL_AUDIT=
DISCORD_CHANNEL_ALERTS=

# Discord Webhooks — for rich agent identity (per-agent username + avatar on
# each message). Create webhooks via Server Settings > Integrations > Webhooks.
# If a department webhook is not set, the bot adapter sends plain markdown.
DISCORD_WEBHOOK_EXECUTIVE=
DISCORD_WEBHOOK_DEVELOPMENT=
DISCORD_WEBHOOK_OPERATIONS=
DISCORD_WEBHOOK_MARKETING=
DISCORD_WEBHOOK_FINANCE=
DISCORD_WEBHOOK_SUPPORT=
DISCORD_WEBHOOK_AUDIT=
DISCORD_WEBHOOK_ALERTS=
DISCORD_WEBHOOK_GENERAL=

# ---------------------------------------------------------------------------
# AO orchestration
# ---------------------------------------------------------------------------

# Core → AO connection
AO_SERVICE_URL=http://ao:8420
AO_AUTH_TOKEN=
AO_DEFAULT_AGENT=claude-code
# Which AO project to start (required when multiple projects configured)
YCLAW_AO_PROJECT=yclaw

# AO container config (used by docker-compose ao service)
AO_CALLBACK_URL=http://yclaw:3000/api/ao/callback
AO_MAX_CONCURRENT=2
YCLAW_REPOS=YClawAI/YClaw

# AO notifications
AO_SLACK_CHANNEL=
AO_SLACK_NOTIFICATIONS=false

# ---------------------------------------------------------------------------
# X / social publishing
# ---------------------------------------------------------------------------

TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTERAPI_IO_KEY=

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
# Reserved; runtime support is incomplete
TIKTOK_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CHAT_ID=
TELEGRAM_ANNOUNCEMENT_CHAT_ID=
TELEGRAM_POLLING=true
TELEGRAM_PAIRING_REQUIRED=
TELEGRAM_PAIRING_CODE=
TELEGRAM_ALLOWED_SENDER_IDS=
TELEGRAM_ADMIN_IDS=

# ---------------------------------------------------------------------------
# Email and AWS
# ---------------------------------------------------------------------------

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=

# S3 object storage (when SECRET_BACKEND/IObjectStore is set to S3)
YCLAW_S3_BUCKET=
YCLAW_S3_PREFIX=

# Legacy AWS Secrets Manager prefix (used by AwsSecretsProvider — note
# the singular form; the newer secret-backends/aws.ts uses AWS_SECRETS_PREFIX
# in the "Integration Secret Backend" section below).
AWS_SECRET_PREFIX=yclaw/

# ---------------------------------------------------------------------------
# Wallets and on-chain data
# ---------------------------------------------------------------------------

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETH_RPC_URL=https://eth.llamarpc.com
TREASURY_WALLET_ADDRESS=
FEE_PAYER_WALLET_ADDRESS=
# JSON array for Mission Control wallet views
WALLET_CONFIG=
HELIUS_API_KEY=
ALCHEMY_API_KEY=

# ---------------------------------------------------------------------------
# External data sources
# ---------------------------------------------------------------------------

YCLAW_MCP_ENDPOINT=
REDIS_CLOUD_API_KEY=
REDIS_CLOUD_SECRET_KEY=

# (optional) Stitch integration API key
STITCH_API_KEY=

MONGODB_ATLAS_PUBLIC_KEY=
MONGODB_ATLAS_PRIVATE_KEY=
MONGODB_ATLAS_ORG_ID=

TELLER_CERTIFICATE=
TELLER_PRIVATE_KEY=
TELLER_ACCESS_TOKENS=

# ---------------------------------------------------------------------------
# Creative and design integrations
# ---------------------------------------------------------------------------

FIGMA_ACCESS_TOKEN=

# Deprecated but still referenced by Terraform and older docs.
FLUX_API_KEY=

# ---------------------------------------------------------------------------
# Integration Secret Backend (Phase 4)
# ---------------------------------------------------------------------------

# mongodb | aws | env | file
SECRET_BACKEND=mongodb
# 64-char hex (AES-256 key) — required for mongodb and file backends.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_SECRET_KEY=
# For file backend: where encrypted secret files are stored
SECRETS_DIR=./data/secrets
# For env backend: path to env file for credentials
SECRETS_ENV_FILE=.env.integrations
# For aws backend: Secrets Manager name prefix
AWS_SECRETS_PREFIX=yclaw/integrations/
# YClaw Agents API for Tier 3 fleet wiring (optional)
YCLAW_AGENTS_URL=http://localhost:3000
# MC URL for ConnectionReporter callbacks
MISSION_CONTROL_URL=http://localhost:3001
