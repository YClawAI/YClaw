# YCLAW — S3 Backend Configuration (Recommended for Teams)
#
# Using local state is DANGEROUS for production — it contains secrets in
# plaintext and has no locking, so concurrent applies can corrupt state.
#
# To use S3 backend:
# 1. Create the S3 bucket and DynamoDB table (one-time):
#    aws s3 mb s3://yclaw-terraform-state-ACCOUNT_ID
#    aws dynamodb create-table --table-name yclaw-terraform-lock \
#      --attribute-definitions AttributeName=LockID,AttributeType=S \
#      --key-schema AttributeName=LockID,KeyType=HASH \
#      --billing-mode PAY_PER_REQUEST
#
# 2. Copy this file to backend.tf and fill in your values:

# terraform {
#   backend "s3" {
#     bucket         = "yclaw-terraform-state-ACCOUNT_ID"
#     key            = "yclaw/terraform.tfstate"
#     region         = "us-east-1"
#     dynamodb_table = "yclaw-terraform-lock"
#     encrypt        = true
#   }
# }
