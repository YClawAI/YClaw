# YCLAW AWS Deployment — Example Variables
# Copy to terraform.auto.tfvars.json (generated by yclaw deploy) or set manually.
# This file is for reference only — yclaw deploy generates the actual tfvars.

# General
project_name = "yclaw"
aws_region   = "us-east-1"
cost_tier    = "starter"  # starter (~$50-80/mo) or production (~$300+/mo)

# Database — default: external MongoDB (e.g. Atlas free tier)
database_type = "external"
mongodb_uri   = "mongodb+srv://user:pass@cluster.mongodb.net/yclaw_agents"

# To use AWS DocumentDB instead:
# database_type = "documentdb"
# mongodb_uri   = ""  # auto-generated

# Compute
core_image = "yclaw/core:latest"
mc_image   = "yclaw/mission-control:latest"
ao_image   = "yclaw/ao:latest"
ao_ephemeral_storage_gib = 50

# GitHub + AO autonomy
github_owner  = "YourOrg"
github_repo   = "your-repo"
yclaw_repos   = "YourOrg/your-repo"
# ao_auth_token = "generate-with-openssl-rand-base64-32"

# HTTPS (recommended for production)
# acm_certificate_arn = "arn:aws:acm:us-east-1:123456789:certificate/abc-123"
# domain_name         = "agents.example.com"

# Application secrets (sensitive — use env vars or -var flag, not this file)
# setup_token      = "..."
# event_bus_secret = "..."
# llm_api_key      = "..."
# github_app_id              = "..."
# github_app_private_key     = "..."
# github_app_installation_id = "..."
# github_token               = "..."
