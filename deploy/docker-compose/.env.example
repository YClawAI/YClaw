# YCLAW Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# Generated values (API keys, secrets) should NEVER be committed to version control.

# ─── Core Runtime ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_PORT=3000

# ─── Compose Profiles ─────────────────────────────────────────────────────
# Set to "bundled" to start local MongoDB, Redis, PostgreSQL containers.
# Remove or leave empty to use external database services.
COMPOSE_PROFILES=bundled

# ─── Database Connection Strings ──────────────────────────────────────────
# When COMPOSE_PROFILES=bundled, these point to the local containers.
# When using external services, set these to your connection strings.
MONGODB_URI=mongodb://mongodb:27017/yclaw_agents
REDIS_URL=redis://redis:6379
MEMORY_DATABASE_URL=postgresql://yclaw:yclaw_dev@postgres:5432/yclaw_memory

# ─── PostgreSQL (bundled mode only) ──────────────────────────────────────
POSTGRES_PASSWORD=yclaw_dev

# ─── LLM Provider ────────────────────────────────────────────────────────
# Fill in the key for your chosen provider. Only one is required.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=...

# ─── Channel Tokens (fill in only the channels you enabled) ──────────────
# SLACK_BOT_TOKEN=xoxb-...
# TELEGRAM_BOT_TOKEN=...
# DISCORD_BOT_TOKEN=...
# TWITTER_APP_KEY=...
# TWITTER_APP_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_SECRET=...

# ─── Security ────────────────────────────────────────────────────────────
# Auto-generated by yclaw init. Used for event bus HMAC signatures.
EVENT_BUS_SECRET=

# One-time setup token for bootstrapping the root operator.
# Auto-generated by yclaw init. Used once during first deploy.
YCLAW_SETUP_TOKEN=

# ─── Agent Orchestrator (AO) ────────────────────────────────────────────
# AO_AUTH_TOKEN=           # Shared secret between core and AO bridge
# GITHUB_APP_ID=           # GitHub App ID for AO's git operations
# GITHUB_APP_PRIVATE_KEY=  # GitHub App private key (base64 or PEM)
# GITHUB_APP_INSTALLATION_ID=  # GitHub App installation ID

# ─── Mission Control ─────────────────────────────────────────────────────
MC_PORT=3001

# ─── Image Version (production mode) ─────────────────────────────────────
# YCLAW_VERSION=latest
